generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum ReservationStatus {
  PENDING
  AWAITING_APPROVAL
  APPROVED
  CONFIRMED
  REJECTED
  CANCELLED
  FAILED
}

model User {
  id           String        @id @default(uuid())
  fullName     String        @map("full_name")
  email        String        @unique
  phone        String
  createdAt    DateTime      @default(now()) @map("created_at")
  reservations Reservation[]

  @@map("users")
}

model Villa {
  id               String        @id @default(uuid())
  name             String
  slug             String        @unique
  description      String
  location         String
  address          String        @default("")
  contactEmail     String        @default("ahmethafi@gmail.com") @map("contact_email")
  contactPhone     String        @default("+90 533 590 05 90") @map("contact_phone")
  maxGuest         Int           @map("max_guest")
  defaultMinNights Int           @default(2) @map("default_min_nights")
  baseNightlyPrice Decimal       @db.Decimal(10, 2) @map("base_nightly_price")
  cleaningFee      Decimal       @db.Decimal(10, 2) @default(0) @map("cleaning_fee")
  depositFee       Decimal       @db.Decimal(10, 2) @default(0) @map("deposit_fee")
  images           String[]
  videos           String[]      @default([])
  amenities        String[]
  isActive         Boolean       @default(true) @map("is_active")
  // { en: { name, description, location, address, amenities: string[] }, de: {...}, ru: {...} }
  translations     Json?
  createdAt        DateTime      @default(now()) @map("created_at")
  reservations     Reservation[]

  @@map("villa")
}

model Reservation {
  id               String                    @id @default(uuid())
  reservationCode  String                    @unique @map("reservation_code")
  userId           String                    @map("user_id")
  user             User                      @relation(fields: [userId], references: [id])
  villaId          String                    @map("villa_id")
  villa            Villa                     @relation(fields: [villaId], references: [id])
  checkIn          DateTime                  @map("check_in")
  checkOut         DateTime                  @map("check_out")
  guestCount       Int                       @map("guest_count")
  nightCount       Int                       @map("night_count")
  nightlyPrice     Decimal                   @db.Decimal(10, 2) @map("nightly_price")
  cleaningFee      Decimal                   @db.Decimal(10, 2) @map("cleaning_fee")
  depositFee       Decimal                   @db.Decimal(10, 2) @map("deposit_fee")
  totalPrice       Decimal                   @db.Decimal(10, 2) @map("total_price")
  note             String?
  // [{ gender: "male"|"female", firstName, lastName }, ...] — misafir bilgileri
  guests           Json?
  discountTotal    Decimal                   @db.Decimal(10, 2) @default(0) @map("discount_total")
  // [{ type, label, percentage, amount }, ...] — uygulanan indirimler
  discounts        Json?
  paymentStatus    PaymentStatus             @default(PENDING) @map("payment_status")
  reservationStatus ReservationStatus        @default(PENDING) @map("reservation_status")
  createdAt        DateTime                  @default(now()) @map("created_at")
  payment          Payment?
  extraServices    ReservationExtraService[]

  @@index([villaId, checkIn, checkOut])
  @@map("reservations")
}

model Payment {
  id                  String      @id @default(uuid())
  reservationId       String      @unique @map("reservation_id")
  reservation         Reservation @relation(fields: [reservationId], references: [id])
  iyzicoPaymentId     String?     @map("iyzico_payment_id")
  iyzicoConversationId String?    @map("iyzico_conversation_id")
  amount              Decimal     @db.Decimal(10, 2)
  currency            String      @default("USD")
  status              PaymentStatus @default(PENDING)
  rawResponse         Json?       @map("raw_response")
  createdAt           DateTime    @default(now()) @map("created_at")

  @@map("payments")
}

model ExtraService {
  id            String                    @id @default(uuid())
  name          String
  description   String?
  price         Decimal                   @db.Decimal(10, 2)
  isActive      Boolean                   @default(true) @map("is_active")
  // { en: { name, description }, de: {...}, ru: {...} }
  translations  Json?
  reservations  ReservationExtraService[]

  @@map("extra_services")
}

model ReservationExtraService {
  id              String       @id @default(uuid())
  reservationId   String       @map("reservation_id")
  reservation     Reservation  @relation(fields: [reservationId], references: [id])
  extraServiceId  String       @map("extra_service_id")
  extraService    ExtraService @relation(fields: [extraServiceId], references: [id])
  quantity        Int          @default(1)
  totalPrice      Decimal      @db.Decimal(10, 2) @map("total_price")

  @@map("reservation_extra_services")
}

// Manuel olarak dolu işaretlenen günler (ör. Airbnb'de kiralanan tarihler).
model BlockedDate {
  id        String   @id @default(uuid())
  date      DateTime @unique @db.Date
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("blocked_dates")
}

// Müşteri yorumları — yalnızca e-postası tamamlanmış bir konaklamayla eşleşen
// kişilerin yorumu sitede görünür olur. Admin panelinden gizlenebilir/silinebilir.
model Review {
  id              String   @id @default(uuid())
  name            String
  email           String
  rating          Int
  comment         String
  isVisible       Boolean  @default(true) @map("is_visible")
  reservationCode String?  @map("reservation_code")
  reply           String?
  repliedAt       DateTime? @map("replied_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([isVisible, createdAt])
  @@map("reviews")
}

// İndirim/kampanya kuralları. Üç yerleşik tür (MOBILE, WELCOME, LAST_MINUTE)
// migration ile eklenir; admin bunları aç/kapatabilir. DATE_RANGE türünde tarih
// aralığına özel kampanyalar admin panelinden eklenip silinebilir.
model Promotion {
  id             String    @id @default(uuid())
  type           String    // MOBILE | WELCOME | LAST_MINUTE | DATE_RANGE | WEEKLY | MONTHLY
  label          String
  percentage     Int
  isActive       Boolean   @default(true) @map("is_active")
  maxRedemptions Int?      @map("max_redemptions") // WELCOME: ilk N müşteri
  daysBefore     Int?      @map("days_before")     // LAST_MINUTE: giriş tarihine en az N gün önce
  minNights      Int?      @map("min_nights")      // WEEKLY/MONTHLY: en az N gece
  startDate      DateTime? @db.Date @map("start_date") // DATE_RANGE
  endDate        DateTime? @db.Date @map("end_date")   // DATE_RANGE
  createdAt      DateTime  @default(now()) @map("created_at")

  @@map("promotions")
}

// Minimum konaklama kuralları — belirli tarih aralıkları için en az gece sayısı.
// Örn. 01 Haziran-30 Eylül → 5 gece. Hiçbir kural uymazsa Villa.defaultMinNights.
model StayRule {
  id        String   @id @default(uuid())
  label     String
  minNights Int      @map("min_nights")
  startDate DateTime @db.Date @map("start_date")
  endDate   DateTime @db.Date @map("end_date")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("stay_rules")
}

model AdminSetting {
  id                 Int       @id @default(1)
  passwordHash       String?   @map("password_hash")
  resetCodeHash      String?   @map("reset_code_hash")
  resetCodeExpiresAt DateTime? @map("reset_code_expires_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@map("admin_settings")
}

model ContactMessage {
  id        String   @id @default(uuid())
  fullName  String   @map("full_name")
  email     String
  phone     String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_messages")
}
